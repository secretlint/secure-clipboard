#!/usr/bin/env bash
# secure-pbcopy: pbcopy with secretlint masking
set -euo pipefail

# Resolve symlinks to find the real script location in the .app bundle
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    SOURCE="$(readlink "$SOURCE")"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# Find secretlint binary in the app bundle
SECRETLINT="${SCRIPT_DIR}/SecureClipboard_SecureClipboard.bundle/Resources/secretlint"
if [ ! -x "$SECRETLINT" ]; then
    SECRETLINT="${SCRIPT_DIR}/../Resources/SecureClipboard_SecureClipboard.bundle/Resources/secretlint"
fi
if [ ! -x "$SECRETLINT" ]; then
    echo "Error: secretlint binary not found" >&2
    exit 1
fi

CONFIG_FILE="${HOME}/.config/secure-clipboard/config.json"
DEFAULT_CONFIG='{"rules":[{"id":"@secretlint/secretlint-rule-preset-recommend"}]}'

# Extract rules from config.json using python3 (available on macOS by default)
if [ -f "$CONFIG_FILE" ]; then
    CONFIG=$(python3 -c "
import json, sys
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
rules = cfg.get('rules', [])
patterns = [p for p in cfg.get('patterns', []) if p.get('action') == 'mask']
if patterns:
    rules.append({'id': '@secretlint/secretlint-rule-pattern', 'options': {'patterns': [{'name': p['name'], 'pattern': p['pattern']} for p in patterns]}})
print(json.dumps({'rules': rules}))
" 2>/dev/null || echo "$DEFAULT_CONFIG")
else
    CONFIG="$DEFAULT_CONFIG"
fi

# secretlint exits 1 when secrets found (not an error)
("$SECRETLINT" --stdinFileName clipboard.txt --format mask-result --secretlintrcJSON "$CONFIG" 2>/dev/null || true) | pbcopy
